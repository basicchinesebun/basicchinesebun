// ── Order actions ──
function oneActionDone(i) {
  const orders=getOrders(); const o=orders[i];
  if (o.done||o.cancelled) return;
  undoStack.push({index:i,snapshot:JSON.parse(JSON.stringify(o))});
  if (undoStack.length>20) undoStack.shift();
  o.called=true; o.done=true; saveOrders(orders);
  announce(o.num); addSale(o); deductStock(o.items, o.type==='online'?'online':'walkin');
  const qs=JSON.parse(localStorage.getItem('queue_state')||'{"next":1,"serving":0}');
  qs.serving=o.num; localStorage.setItem('queue_state',JSON.stringify(qs));
  if (autoPrint) printOrder(i);
  toast(`✅ ຄິວ ${String(o.num).padStart(3,'0')} Done!`,'green'); render();
}
function callOnly(i) {
  const orders=getOrders(); orders[i].called=true; saveOrders(orders);
  announce(orders[i].num);
  const qs=JSON.parse(localStorage.getItem('queue_state')||'{"next":1,"serving":0}');
  qs.serving=orders[i].num; localStorage.setItem('queue_state',JSON.stringify(qs)); render();
}
function cancelOrder(i) {
  const orders=getOrders();
  undoStack.push({index:i,snapshot:JSON.parse(JSON.stringify(orders[i]))});
  // หักเงินออกจากยอดขายเสมอ ไม่ว่าจะ Done หรือยัง
  remSale(orders[i]);
  orders[i].cancelled=true; orders[i].done=false; saveOrders(orders);
  toast('ຍົກເລີກ — ກົດ ↩ ຄືນໄດ້','orange'); render();
}
function undoCancel(i) {
  const orders=getOrders();
  orders[i].cancelled=false;
  // คืนเงินกลับเข้ายอดขายถ้าออเดอร์นี้เคย Done
  if (orders[i].done) addSale(orders[i]);
  saveOrders(orders);
  toast('↩ ຄືນອໍເດີ','blue'); render();
}
function undoDone(i) {
  const orders=getOrders();
  if (orders[i].done) { remSale(orders[i]); orders[i].done=false; orders[i].called=false; }
  saveOrders(orders);
  const mn=getMenuNames(),st=getStock();
  orders[i].items.split('\n').forEach(line=>{
    if (!line.trim()) return;
    const qty=parseInt((line.match(/x(\d+)/)||[,'1'])[1]);
    const idx=mn.findIndex(m=>line.includes(m.lo));
    if (idx>=0) st[idx]=(st[idx]||0)+qty;
  });
  saveStock(st); renderStock();
  toast('↩ ຍົກເລີກ Done','blue'); render();
}

// ── Bluetooth Printer ──
async function connectPrinter() {
  const bar=document.getElementById('pStatus'),btn=document.getElementById('printerBtn');
  if (btChar) {
    try{await btDevice.gatt.disconnect();}catch(e){}
    btDevice=null;btChar=null;bar.classList.remove('show');
    btn.textContent='🖨 ເຊື່ອມ';btn.className='hbtn blue';toast('ຕັດການເຊື່ອມ'); return;
  }
  bar.textContent='🔍 ກຳລັງຊອກຫາ...';bar.className='pstatus show connecting';
  try {
    btDevice=await navigator.bluetooth.requestDevice({
      filters:[{services:['000018f0-0000-1000-8000-00805f9b34fb']}],
      optionalServices:['000018f0-0000-1000-8000-00805f9b34fb','49535343-fe7d-4ae5-8fa9-9fafd205e455']
    });
    const srv=await btDevice.gatt.connect();let svc,chr;
    try{svc=await srv.getPrimaryService('000018f0-0000-1000-8000-00805f9b34fb');chr=await svc.getCharacteristic('00002af1-0000-1000-8000-00805f9b34fb');}
    catch(e){svc=await srv.getPrimaryService('49535343-fe7d-4ae5-8fa9-9fafd205e455');chr=await svc.getCharacteristic('49535343-8841-43f4-a8d4-ecbe34729bb3');}
    btChar=chr;
    bar.textContent='✅ '+(btDevice.name||'Printer');bar.className='pstatus show connected';
    btn.textContent='✅ '+(btDevice.name||'Printer');btn.className='hbtn green';
    toast('ເຊື່ອມເຄື່ອງພິມ ✅','green');
  } catch(e) {
    bar.textContent='❌ '+e.message;bar.className='pstatus show error';
    btChar=null;toast('ເຊື່ອມຕໍ່ຜິດພາດ','red');
    setTimeout(()=>bar.classList.remove('show'),4000);
  }
}
async function printOrder(i) {
  const o=getOrders()[i];
  const cfg=JSON.parse(localStorage.getItem('bcb_receipt')||'{}');
  const sn=cfg.shopName||'Basic Chinese Bun',addr=cfg.address||'',phone=cfg.phone||'';
  const footer=cfg.footer||'ຂອບໃຈທີ່ໃຊ້ບໍລິການ';
  const ropts=cfg.opts||{showQnum:true,showItems:true,showTotal:true,showTime:true,autoCut:true};
  const lines=[];
  lines.push({t:sn,b:1,c:1,s:2});if(addr)lines.push({t:addr,c:1});if(phone)lines.push({t:phone,c:1});
  lines.push({t:'--------------------------------',c:1});
  if(ropts.showQnum!==false){lines.push({t:'ຄິວ / QUEUE',c:1});lines.push({t:'* '+String(o.num).padStart(3,'0')+' *',b:1,c:1,s:2});}
  if(ropts.showTime!==false)lines.push({t:'ເວລາ: '+o.time});
  lines.push({t:'--------------------------------',c:1});
  if(ropts.showItems!==false){o.items.split('\n').filter(l=>l.trim()).forEach(l=>lines.push({t:l}));lines.push({t:'--------------------------------',c:1});}
  if(ropts.showTotal!==false&&o.total)lines.push({t:'ລວມ: '+o.total.toLocaleString()+' ກີບ',b:1});
  lines.push({t:''});lines.push({t:footer,c:1});lines.push({t:''},{t:''},{t:''});
  if(!btChar){toast('ຍັງບໍ່ໄດ້ເຊື່ອມ','orange');return;}
  try{
    const buf=[],enc=new TextEncoder();buf.push(ESC,0x40);
    lines.forEach(({t,b,c,s})=>{buf.push(ESC,0x61,c?1:0);buf.push(ESC,0x45,b?1:0);buf.push(GS,0x21,s===2?0x11:0x00);enc.encode(t+'\n').forEach(x=>buf.push(x));});
    buf.push(ESC,0x64,0x04);if(ropts.autoCut!==false)buf.push(GS,0x56,0x41,0x00);
    const bytes=new Uint8Array(buf);
    for(let j=0;j<bytes.length;j+=200){await btChar.writeValue(bytes.slice(j,j+200));await new Promise(r=>setTimeout(r,50));}
    toast('ພິມສຳເລັດ 🖨','green');
  }catch(e){toast('ພິມຜິດພາດ: '+e.message,'red');}
}

