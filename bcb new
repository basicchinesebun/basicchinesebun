  logoData=null;document.getElementById('logoImg').src='';document.getElementById('logoImg').style.display='none';
  document.getElementById('logoIcon').style.display='block';document.getElementById('logoRm').style.display='none';
  localStorage.removeItem('bcb_logo');updatePreview();
}
function loadReceipt(){
  const s=localStorage.getItem('bcb_receipt');
  if(s){
    const c=JSON.parse(s);
    document.getElementById('shopName').value=c.shopName||'';
    document.getElementById('address').value=c.address||'';
    document.getElementById('phone').value=c.phone||'';
    document.getElementById('rfooter').value=c.footer||'';
    if(c.opts){Object.assign(ropts,c.opts);Object.keys(ropts).forEach(k=>{const b=document.getElementById('tog-'+k);if(b)b.classList.toggle('on',ropts[k]);});}
  }
  const lg=localStorage.getItem('bcb_logo');
  if(lg){logoData=lg;document.getElementById('logoImg').src=lg;document.getElementById('logoImg').style.display='block';document.getElementById('logoIcon').style.display='none';document.getElementById('logoRm').style.display='block';}
  updatePreview();
}
function saveReceipt(){
  localStorage.setItem('bcb_receipt',JSON.stringify({shopName:document.getElementById('shopName').value||'Basic Chinese Bun',address:document.getElementById('address').value,phone:document.getElementById('phone').value,footer:document.getElementById('rfooter').value||'ຂອບໃຈທີ່ໃຊ້ບໍລິການ',opts:Object.assign({},ropts)}));
  const m=document.getElementById('savedMsg');m.style.display='block';setTimeout(()=>m.style.display='none',2000);
}
function buildReceiptHTML(qnum,items,total,time){
  const sn=document.getElementById('shopName').value||'Basic Chinese Bun';
  const addr=document.getElementById('address').value,phone=document.getElementById('phone').value;
  const footer=document.getElementById('rfooter').value||'ຂອບໃຈທີ່ໃຊ້ບໍລິການ';
  let h='';
  if(ropts.showLogo&&logoData)h+=`<img class="r-logo" src="${logoData}">`;
  h+=`<div class="r-shop">${sn}</div>`;
  if(addr)h+=`<div class="r-addr">${addr}</div>`;
  if(phone)h+=`<div class="r-phone">${phone}</div>`;
  h+=`<hr class="r-div">`;
  if(ropts.showQnum){h+=`<div class="r-qlbl">ຄິວ · QUEUE</div><div class="r-qnum">${String(qnum).padStart(3,'0')}</div>`;}
  if(ropts.showTime)h+=`<div class="r-time">ເວລາ: ${time}</div>`;
  h+=`<hr class="r-div">`;
  if(ropts.showItems){items.split('\n').filter(l=>l.trim()).forEach(line=>{const p=line.split('=');h+=`<div class="r-item"><span>${p[0].trim()}</span><span>${p[1]?p[1].trim():''}</span></div>`;});h+=`<hr class="r-div">`;}
  if(ropts.showTotal&&total)h+=`<div class="r-total"><span>ລວມທັງໝົດ</span><span>${total.toLocaleString()} ກີບ</span></div>`;
  h+=`<hr class="r-div"><div class="r-foot">${footer.replace(/\n/g,'<br>')}</div>`;
  return h;
}
function updatePreview(){
  document.getElementById('receiptPreview').innerHTML=buildReceiptHTML(7,'ຊາລາເປົາໝູສັບ x2 = 40,000 ກີບ\nໝັນໂຖ Matcha x1 = 15,000 ກີບ',55000,'14:30');
}
function printTest(){alert('ຕົວຢ່າງໃບບິນ — ກົດ "ເຊື່ອມ" ແລ້ວກົດ 🖨 ທີ່ອໍເດີ');}

// ── Init ──
loadSettings();
renderStock();
renderQRAdmin();
buildMenuSettings();
render();
renderShopStatus();
window.addEventListener('storage',()=>{render();checkNotif();renderStock();});
setInterval(()=>{render();checkNotif();},2000);

// ══ FIREBASE — Online Orders ══
// ⚠️ ใส่ config เดียวกับ order.html
const FB_CONFIG = {
  apiKey: "AIzaSyBttrWZXEeC-_zgiHftpHTspqlJL_CeSgQ",
  authDomain: "basic-chinese-bun.firebaseapp.com",
  databaseURL: "https://basic-chinese-bun-default-rtdb.firebaseio.com",
  projectId: "basic-chinese-bun",
  storageBucket: "basic-chinese-bun.firebasestorage.app",
  messagingSenderId: "893711620048",
  appId: "1:893711620048:web:3fcfa7aa5f808d25bd8bd5"
};

let fbApp=null, fbDb=null;
async function initFirebase(){
  if(fbDb) return;
  try{
    const {initializeApp}=await import('https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js');
    const {getDatabase,ref,onValue,update}=await import('https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js');
    fbApp=initializeApp(FB_CONFIG,'staff');
    fbDb=getDatabase(fbApp);
    // ดึงข้อมูลจาก Firebase มา localStorage เมื่อเปิดครั้งแรก
    const {get} = await import('https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js');
    const [menuSnap, priceSnap, stockSnap, qrSnap, shopSnap] = await Promise.all([
      get(ref(fbDb,'settings/menus')),
      get(ref(fbDb,'settings/prices')),
      get(ref(fbDb,'stock/online')),
      get(ref(fbDb,'settings/qr')),
      get(ref(fbDb,'shop')),
    ]);
    if(menuSnap.exists()) { localStorage.setItem('bcb_menus', JSON.stringify(menuSnap.val())); }
    if(priceSnap.exists()) { localStorage.setItem('bcb_prices', JSON.stringify(priceSnap.val())); }
    if(stockSnap.exists()) { localStorage.setItem('bcb_stock_online', JSON.stringify(stockSnap.val())); }
    if(qrSnap.exists()) { localStorage.setItem('bcb_qr', qrSnap.val()); renderQRAdmin(); }
    if(shopSnap.exists()) { localStorage.setItem('bcb_shop', JSON.stringify(shopSnap.val())); renderShopStatus(); }
    // โหลดรูปเมนู
    for(let i=0; i<7; i++) {
      const imgSnap = await get(ref(fbDb,'settings/img_'+i));
      if(imgSnap.exists()) localStorage.setItem('bcb_img_'+i, imgSnap.val());
    }
    loadSettings(); renderStock(); buildMenuSettings();
    // Listen online orders realtime
    onValue(ref(fbDb,'orders'),(snap)=>{
      if(!snap.exists()) return;
      const fbOrders=Object.values(snap.val()).filter(o=>o.type==='online');
      mergeOnlineOrders(fbOrders);
    });
    // Sync settings to Firebase
    syncSettingsToFirebase(getDatabase, ref, fbDb);
    toast('☁ ເຊື່ອມ Firebase ✅','green');
  }catch(e){ toast('Firebase: '+e.message,'orange'); }
}

function mergeOnlineOrders(fbOrders){
  // merge online orders into render
  const localOrders=getOrders();
  const onlineNums=new Set(fbOrders.map(o=>o.num));
  // remove old online orders from local
  const filtered=localOrders.filter(o=>o.type!=='online'||onlineNums.has(o.num));
  // add/update from Firebase
  fbOrders.forEach(fo=>{
    const idx=filtered.findIndex(o=>o.num===fo.num&&o.type==='online');
    if(idx>=0) filtered[idx]={...filtered[idx],...fo};
    else filtered.push(fo);
  });
  filtered.sort((a,b)=>b.num-a.num);
  saveOrders(filtered);
  render();
}

async function confirmSlip(num){
  if(!fbDb){toast('ຍັງບໍ່ໄດ້ເຊື່ອມ Firebase','orange');return;}
  const {ref,update}=await import('https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js');
  await update(ref(fbDb,`orders/${num}`),{status:'confirmed'});
  const orders=getOrders();
  const idx=orders.findIndex(o=>o.num===num);
  if(idx>=0){orders[idx].status='confirmed';saveOrders(orders);}
  toast(`✅ ຢືນຢັນສລິບ ຄິວ ${String(num).padStart(3,'0')}`, 'green');
  render();
}

async function rejectSlip(num){
  if(!fbDb){toast('ຍັງບໍ່ໄດ້ເຊື່ອມ Firebase','orange');return;}
  const {ref,update}=await import('https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js');
  await update(ref(fbDb,`orders/${num}`),{status:'rejected',cancelled:true});
  const orders=getOrders();
  const idx=orders.findIndex(o=>o.num===num);
  if(idx>=0){orders[idx].status='rejected';orders[idx].cancelled=true;saveOrders(orders);}
  toast(`❌ ປະຕິເສດ ຄິວ ${String(num).padStart(3,'0')}`,'red');
  render();
}

// Sync menus/prices/QR to Firebase so order.html loads them
async function syncSettingsToFirebase(getDatabase,ref,db){
  try{
    const {set}=await import('https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js');
    const menus=localStorage.getItem('bcb_menus');
    const prices=localStorage.getItem('bcb_prices');
    const qr=localStorage.getItem('bcb_qr');
    const stockOnline=localStorage.getItem('bcb_stock_online');
    const stockWalkin=localStorage.getItem('bcb_stock_walkin');
    if(menus) await set(ref(db,'settings/menus'),JSON.parse(menus));
    if(prices) await set(ref(db,'settings/prices'),JSON.parse(prices));
    if(qr) await set(ref(db,'settings/qr'),qr);
    if(stockOnline) await set(ref(db,'stock/online'),JSON.parse(stockOnline));
    if(stockWalkin) await set(ref(db,'stock/walkin'),JSON.parse(stockWalkin));
  }catch(e){}
}

// Auto init Firebase on load
initFirebase();
</script>
</body>
