.sbtn{width:100%;padding:14px;background:var(--warm-white);color:var(--brown);border:2.5px solid var(--brown);border-radius:var(--radius);font-size:clamp(14px,2vw,16px);font-weight:900;cursor:pointer;text-align:center;}

/* Menu Grid */
.slabel{font-size:clamp(12px,2vw,14px);font-weight:900;color:var(--gray3);letter-spacing:0.3px;text-transform:uppercase;margin-bottom:10px;text-align:center;}
