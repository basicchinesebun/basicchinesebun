      <div class="scard-head"><div class="scard-qnum">ຄິວ ${String(o.num).padStart(3,'0')}</div><div class="scard-time">${o.time}</div></div>
      <div class="scard-items">${o.items}</div>
      ${o.total?`<div class="scard-total">${o.total.toLocaleString()} ກີບ</div>`:''}
    </div>`).join('');
}
