function loadDates(){
  const sales=getSales();const dates=Object.keys(sales).sort().reverse();
  const today=new Date().toLocaleDateString('lo-LA');
  if(!dates.includes(today))dates.unshift(today);
  const sel=document.getElementById('dateSelect');
  sel.innerHTML=dates.map(d=>`<option value="${d}" ${d===today?'selected':''}>${d}</option>`).join('');
