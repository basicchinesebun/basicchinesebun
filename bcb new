<script type="module">
// ══════════════════════════════════════
// FIREBASE CONFIG — ใส่ config ของคุณตรงนี้
// ══════════════════════════════════════
import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js';
import { getDatabase, ref, push, set, get, onValue } from 'https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js';

const firebaseConfig = {
  apiKey: "AIzaSyBttrWZXEeC-_zgiHftpHTspqlJL_CeSgQ",
  authDomain: "basic-chinese-bun.firebaseapp.com",
  databaseURL: "https://basic-chinese-bun-default-rtdb.firebaseio.com",
  projectId: "basic-chinese-bun",
  storageBucket: "basic-chinese-bun.firebasestorage.app",
  messagingSenderId: "893711620048",
  appId: "1:893711620048:web:3fcfa7aa5f808d25bd8bd5"
};

const app = initializeApp(firebaseConfig);
const db = getDatabase(app);

// ══════════════════════════════════════
// STATE
// ══════════════════════════════════════
const EMOJIS = ['🥟','🍫','🍵','🧁','🍞','🥐','🍮'];
const BAG_LABELS = ['','🛍 ຖົງດຽວລວມທັງໝົດ','📦 ແຍກຕາມປະເພດເມນູ','1️⃣ ແຍກທີລະກ້ອນ'];
let menus = [], prices = [], selected = [], quantities = [];
let selectedBagType = 0, currentTotal = 0;
let slipFile = null, slipDataUrl = null;

// ══════════════════════════════════════
// TOAST
// ══════════════════════════════════════
function toast(msg, type='', dur=2500) {
  const el = document.createElement('div');
  el.className = `toast-item ${type}`; el.textContent = msg;
  document.getElementById('toast').appendChild(el);
  setTimeout(() => el.style.opacity='0', dur-300);
  setTimeout(() => el.remove(), dur);
}

// ══════════════════════════════════════
// OFFLINE DETECTION
// ══════════════════════════════════════
window.addEventListener('online', () => document.getElementById('offlineBanner').classList.remove('show'));
window.addEventListener('offline', () => document.getElementById('offlineBanner').classList.add('show'));

// ══════════════════════════════════════
// LOAD DATA FROM FIREBASE
// ══════════════════════════════════════
async function loadData() {
  try {
    // โหลดเมนูจาก Firebase ก่อน ถ้าไม่มีใช้ localStorage
    const menuSnap = await get(ref(db, 'settings/menus'));
    if (menuSnap.exists()) {
      menus = Object.values(menuSnap.val());
    } else {
      const sm = localStorage.getItem('bcb_menus');
      menus = sm ? JSON.parse(sm) : [
        {lo:'ຊາລາເປົາໝູສັບ',en:'Pork Steamed Bun'},
        {lo:'ໝັນໂຖ Dark Chocolate',en:'Dark Choc Mantou'},
        {lo:'ໝັນໂຖ Matcha',en:'Matcha Mantou'},
        {lo:'ເມນູ 4',en:'Menu 4'},
        {lo:'ເມນູ 5',en:'Menu 5'},
        {lo:'ເມນູ 6',en:'Menu 6'},
        {lo:'ເມນູ 7',en:'Menu 7'},
      ];
    }
    const priceSnap = await get(ref(db, 'settings/prices'));
    prices = priceSnap.exists() ? Object.values(priceSnap.val()) : new Array(menus.length).fill(0);

    // โหลด QR
    const qrSnap = await get(ref(db, 'settings/qr'));
    if (qrSnap.exists()) {
      document.getElementById('qrImage').src = qrSnap.val();
      document.getElementById('qrImgWrap').style.display = 'flex';
      document.getElementById('qrPlaceholder').style.display = 'none';
    } else {
      const localQr = localStorage.getItem('bcb_qr');
      if (localQr) {
        document.getElementById('qrImage').src = localQr;
        document.getElementById('qrImgWrap').style.display = 'flex';
        document.getElementById('qrPlaceholder').style.display = 'none';
      }
    }
  } catch(e) {
    // fallback to localStorage
    const sm = localStorage.getItem('bcb_menus');
    menus = sm ? JSON.parse(sm) : [];
    const sp = localStorage.getItem('bcb_prices');
    prices = sp ? JSON.parse(sp) : new Array(menus.length).fill(0);
  }

  while (prices.length < menus.length) prices.push(0);
  selected = new Array(menus.length).fill(false);
  quantities = new Array(menus.length).fill(1);
  buildGrid();
}

// ══════════════════════════════════════
// STOCK (online stock from Firebase)
// ══════════════════════════════════════
function getOnlineStock() {
  return new Promise(async (resolve) => {
    try {
      const snap = await get(ref(db, 'stock/online'));
      if (snap.exists()) {
        const val = snap.val();
        const arr = Array.isArray(val) ? val : Object.values(val);
        // ถ้าทุกตัวเป็น 0 แปลว่ายังไม่ได้ตั้งสต็อก ให้แสดงทั้งหมด
        if (arr.every(v => v === 0)) resolve(new Array(menus.length).fill(99));
        else resolve(arr);
      } else {
        // ไม่มีข้อมูลสต็อก = แสดงทั้งหมด
        resolve(new Array(menus.length).fill(99));
      }
    } catch { resolve(new Array(menus.length).fill(99)); }
  });
}

// ══════════════════════════════════════
// BUILD MENU GRID
// ══════════════════════════════════════
async function buildGrid() {
  const grid = document.getElementById('menuGrid');
  grid.innerHTML = '';
  const stock = await getOnlineStock();
  menus.forEach((m, i) => {
    const img = localStorage.getItem('bcb_img_' + i);
    const isOut = stock[i] === 0;
    const card = document.createElement('div');
    card.className = 'mcard' + (isOut ? ' out' : '');
    card.id = 'card-' + i;
    if (!isOut) card.onclick = () => toggleMenu(i);
    card.innerHTML = `
      <div class="cbadge">✓</div>
      <div class="mimg">
        <div class="memoji" id="em-${i}" style="${img?'display:none':''}">${EMOJIS[i]||'🍱'}</div>
        <img id="im-${i}" src="${img||''}" style="${img?'':'display:none'}">
        ${isOut?'<div class="sold-ov"><span class="sold-lbl">ໝົດແລ້ວ</span></div>':''}
      </div>
      <div class="mfoot">
        <div class="mname">${m.lo}</div>
        <div class="mname-en">${m.en||''}</div>
        <div class="mprice">${isOut?'<span style="color:var(--red)">ໝົດ</span>':prices[i]?prices[i].toLocaleString()+' ກີບ':'—'}</div>
      </div>
      <div class="qrow">
        <div class="qlbl">ຈຳນວນ</div>
        <div class="qctrl">
          <button class="qbtn" onclick="chgQ(event,${i},-1)">−</button>
          <input class="qinput" type="text" inputmode="numeric" id="q-${i}" value="1"
            onclick="this.select();event.preventDefault();"
            onblur="setQ(${i},this.value)"
            onkeydown="if(event.key==='Enter'){setQ(${i},this.value);this.blur();}">
          <button class="qbtn" onclick="chgQ(event,${i},1)">+</button>
        </div>
      </div>`;
    grid.appendChild(card);
  });
}

function toggleMenu(i) {
  selected[i] = !selected[i];
  if (!selected[i]) { quantities[i]=1; const q=document.getElementById('q-'+i); if(q) q.value=1; }
  document.getElementById('card-'+i).classList.toggle('sel', selected[i]);
  document.getElementById('confirmBtn').disabled = !selected.some(s=>s);
}
function setQ(i, val) { const n=Math.max(1,parseInt(val)||1); quantities[i]=n; const inp=document.getElementById('q-'+i); if(inp) inp.value=n; }
function chgQ(e, i, d) {
  e.stopPropagation(); e.preventDefault();
  const inp=document.getElementById('q-'+i);
  const n=Math.max(1,(parseInt(inp?.value||quantities[i])||1)+d);
  quantities[i]=n; if(inp){inp.value=n;inp.blur();}
  if(document.activeElement) document.activeElement.blur();
}

function showStep(n) {
  document.querySelectorAll('.step').forEach(s=>s.classList.remove('active'));
  document.getElementById('step'+n).classList.add('active');
  window.scrollTo(0,0);
}

// ══════════════════════════════════════
// BAG SELECTION
// ══════════════════════════════════════
function goToBag() {
  let total=0;
  selected.forEach((s,i)=>{ if(!s) return; const q=parseInt(document.getElementById('q-'+i)?.value||quantities[i])||1; quantities[i]=q; total+=q; });
  document.getElementById('bagSummary').textContent = `ຂະໜົມທັງໝົດ ${total} ກ້ອນ`;
  selectedBagType=0;
  document.getElementById('bagConfirmBtn').disabled=true;
  [1,2,3].forEach(n=>document.getElementById('bopt'+n)?.classList.remove('sel'));
  showStep(2);
}
function selectBagType(n) {
  selectedBagType=n;
  [1,2,3].forEach(i=>document.getElementById('bopt'+i)?.classList.remove('sel'));
  document.getElementById('bopt'+n)?.classList.add('sel');
  document.getElementById('bagConfirmBtn').disabled=false;
}

// ══════════════════════════════════════
// CUSTOMER INFO
// ══════════════════════════════════════
function goToInfo() { showStep(3); validateInfo(); }
function validateInfo() {
  const name=document.getElementById('custName').value.trim();
  const phone=document.getElementById('custPhone').value.trim();
  const date=document.getElementById('pickupDate').value;
  const time=document.getElementById('pickupTime').value;
  document.getElementById('infoConfirmBtn').disabled = !(name && phone && date && time);
}

// ══════════════════════════════════════
// QR PAGE
// ══════════════════════════════════════
function goToQR() {
  currentTotal=0;
  selected.forEach((s,i)=>{ if(!s) return; currentTotal+=prices[i]*quantities[i]; });
  const el=document.getElementById('qrAmt');
  el.innerHTML=currentTotal?currentTotal.toLocaleString()+' <span class="qr-unit">ກີບ</span>':'— <span class="qr-unit">ກີບ</span>';
  showStep(4);
}

// ══════════════════════════════════════
// SLIP UPLOAD
// ══════════════════════════════════════
function uploadSlip(e) {
  const f=e.target.files[0]; if(!f) return;
  slipFile=f;
  const reader=new FileReader();
  reader.onload=ev=>{
    // บีบอัดรูปก่อนเก็บใน Firebase เพื่อลดขนาด
    const img=new Image();
    img.onload=()=>{
      const canvas=document.createElement('canvas');
      const MAX=600;
      let w=img.width,h=img.height;
      if(w>MAX){h=Math.round(h*MAX/w);w=MAX;}
      if(h>MAX){w=Math.round(w*MAX/h);h=MAX;}
      canvas.width=w;canvas.height=h;
      canvas.getContext('2d').drawImage(img,0,0,w,h);
      slipDataUrl=canvas.toDataURL('image/jpeg',0.55);
      document.getElementById('slipBox').classList.add('has-slip');
      document.getElementById('slipIcon').textContent='✅';
      document.getElementById('slipText').textContent='ສລິບພ້ອມແລ້ວ · ກົດເພື່ອປ່ຽນ';
      document.getElementById('slipPreview').src=slipDataUrl;
      document.getElementById('slipPreview').style.display='block';
      document.getElementById('submitBtn').disabled=false;
      toast('ອັປໂຫລດສລິບ ✅','green');
    };
    img.src=ev.target.result;
  };
  reader.readAsDataURL(f);
}

// ══════════════════════════════════════
// SUBMIT ORDER
// ══════════════════════════════════════
async function submitOrder() {
  const btn=document.getElementById('submitBtn');
  btn.disabled=true; btn.textContent='⏳ ກຳລັງສົ່ງ...';

  // timeout 15 วินาที ถ้า Firebase ไม่ตอบ
  const timeout = new Promise((_,reject) => setTimeout(()=>reject(new Error('ໝົດເວລາ — ກວດສອບອິນເຕີເນັດ')), 30000));

  try {
    await Promise.race([_doSubmit(), timeout]);
  } catch(err) {
    toast('ເກີດຂໍ້ຜິດພາດ: '+err.message,'red');
    btn.disabled=false; btn.textContent='✅ ສ່ງຄຳສັ່ງ · Submit Order';
  }
}

async function _doSubmit() {
  const btn=document.getElementById('submitBtn');
  // Get queue number
  const qSnap=await get(ref(db,'queue_state'));
  const qs=qSnap.exists()?qSnap.val():{next:1};
  const myNum=qs.next||1;

  // Build order items text
  let lines=''; let total=0;
  selected.forEach((s,i)=>{ if(!s) return; const qty=quantities[i]; const sub=prices[i]*qty; total+=sub; lines+=`${menus[i].lo} x${qty}${prices[i]?' = '+sub.toLocaleString()+' ກີບ':''}\n`; });

  // ใช้ base64 เก็บใน Realtime Database โดยตรง ไม่ต้องใช้ Storage
  let slipUrl = slipDataUrl || '';

  const now=new Date().toLocaleTimeString('lo-LA',{hour:'2-digit',minute:'2-digit'});
  const bagNote=document.getElementById('bagNote')?.value?.trim()||'';
  const order={
    num: myNum, type: 'online',
    items: lines.trim(), total, time: now,
    bag: BAG_LABELS[selectedBagType]||'',
    bagNote,
    custName: document.getElementById('custName').value.trim(),
    custPhone: document.getElementById('custPhone').value.trim(),
    pickupDate: document.getElementById('pickupDate').value,
    pickupTime: document.getElementById('pickupTime').value,
    note: document.getElementById('custNote')?.value?.trim()||'',
    slipUrl,
    status: 'pending',
    done: false, cancelled: false, called: false,
    createdAt: Date.now()
  };

  await set(ref(db,`orders/${myNum}`), order);
  await set(ref(db,'queue_state'), {next: myNum+1, serving: qs.serving||0});

  document.getElementById('statusQnum').textContent=String(myNum).padStart(3,'0');
  document.getElementById('statusInfo').innerHTML=`
    <div>👤 ${order.custName}</div>
    <div>📅 ${order.pickupDate} · ${order.pickupTime}</div>
    <div>💰 ${total?total.toLocaleString()+' ກີບ':'—'}</div>
  `;
  showStep(5);
  listenOrderStatus(myNum);
  toast('ສ່ງຄຳສັ່ງ ✅','green');
}

// ══════════════════════════════════════
// LISTEN ORDER STATUS (real-time)
// ══════════════════════════════════════
function listenOrderStatus(num) {
  onValue(ref(db,`orders/${num}/status`), snap=>{
    const status=snap.val()||'pending';
    const badge=document.getElementById('statusBadge');
    if(!badge) return;
    if(status==='confirmed'){
      badge.className='status-badge confirmed';
      badge.textContent='✅ ຢືນຢັນແລ້ວ — ກຽມຮັບຂອງໄດ້ເລີຍ';
      document.querySelector('.status-footer').textContent='🎉 ຂໍ້ມູນຢືນຢັນ ກະລຸນາມາຮັບຕາມເວລາ';
    } else if(status==='rejected'){
      badge.className='status-badge rejected';
      badge.textContent='❌ ປະຕິເສດ — ກະລຸນາຕິດຕໍ່ຮ້ານ';
    } else {
      badge.className='status-badge pending';
      badge.textContent='🟡 ລໍຖ້າຕຣວດສອບສລິບ';
    }
  });
}

// ══════════════════════════════════════
// ORDER HISTORY
// ══════════════════════════════════════
function showHistory() { showStep(6); }
async function searchHistory() {
  const phone=document.getElementById('histPhone').value.trim();
  if(!phone){ toast('ກະລຸນາໃສ່ເບີໂທ','orange'); return; }
  const list=document.getElementById('historyList');
  list.innerHTML='<div style="text-align:center;padding:20px;color:var(--gray3);font-weight:700;">🔍 ກຳລັງຄົ້ນຫາ...</div>';
  try{
    const snap=await get(ref(db,'orders'));
    if(!snap.exists()){ list.innerHTML='<div style="text-align:center;padding:20px;color:var(--gray3);">ບໍ່ພົບຂໍ້ມູນ</div>'; return; }
    const orders=Object.values(snap.val()).filter(o=>o.custPhone===phone && o.type==='online');
    orders.sort((a,b)=>b.createdAt-a.createdAt);
    if(!orders.length){ list.innerHTML='<div style="text-align:center;padding:20px;color:var(--gray3);font-weight:700;">ບໍ່ພົບປະຫວັດ</div>'; return; }
    const statusMap={pending:'🟡 ລໍຖ້າ',confirmed:'✅ ຢືນຢັນ',rejected:'❌ ປະຕິເສດ'};
    const colorMap={pending:'var(--orange)',confirmed:'var(--green)',rejected:'var(--red)'};
    list.innerHTML=orders.map(o=>`
      <div class="hist-card">
        <div class="hist-head">
          <div class="hist-qnum">ຄິວ ${String(o.num).padStart(3,'0')}</div>
          <div class="hist-date">${o.pickupDate||''} ${o.pickupTime||''}</div>
        </div>
        <div class="hist-items">${o.items||''}</div>
        <div class="hist-total">${o.total?o.total.toLocaleString()+' ກີບ':'—'}</div>
        <span class="hist-status" style="background:${colorMap[o.status]||'var(--orange)'};color:white;">${statusMap[o.status]||'🟡 ລໍຖ້າ'}</span>
      </div>`).join('');
  }catch(e){ list.innerHTML='<div style="text-align:center;padding:20px;color:var(--red);">ເກີດຂໍ້ຜິດພາດ</div>'; }
}

