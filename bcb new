      <div style="display:flex;gap:8px;">
        <input id="histPhone" type="tel" placeholder="020 XXXX XXXX" style="flex:1;border:2px solid var(--cream3);border-radius:10px;padding:10px 12px;color:var(--brown);background:var(--cream);">
        <button onclick="searchHistory()" style="padding:10px 16px;background:var(--brown);color:var(--cream);border:none;border-radius:10px;font-size:14px;font-weight:900;white-space:nowrap;">ຄົ້ນຫາ</button>
