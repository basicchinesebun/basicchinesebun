      const g=ctx.createGain();g.gain.value=0.25;g.connect(ctx.destination);
      [880,1100,880].forEach((f,i)=>{const o=ctx.createOscillator();o.connect(g);o.frequency.value=f;o.start(ctx.currentTime+i*0.15);o.stop(ctx.currentTime+i*0.15+0.12);});
    } catch(e){}
  }
  lastPendingCount=pending;
}
