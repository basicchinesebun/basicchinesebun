function loadVoices() { voices = window.speechSynthesis.getVoices(); }
window.speechSynthesis.onvoiceschanged = loadVoices; loadVoices();
const TH1=['','หนึ่ง','สอง','สาม','สี่','ห้า','หก','เจ็ด','แปด','เก้า'];
const TH2=['สิบ','สิบเอ็ด','สิบสอง','สิบสาม','สิบสี่','สิบห้า','สิบหก','สิบเจ็ด','สิบแปด','สิบเก้า'];
const TH3=['','ที่หนึ่ง','ที่สอง','ที่สาม','ที่สี่','ที่ห้า','ที่หก','ที่เจ็ด','ที่แปด','ที่เก้า'];
function numThai(n) {
  if (n===100) return 'ที่หนึ่งร้อย';
  if (n>=20) { const t=Math.floor(n/10),o=n%10; return 'ที่'+TH1[t]+'สิบ'+(o>0?(o===1?'เอ็ด':TH1[o]):''); }
  if (n>=10) return 'ที่'+TH2[n-10]; return TH3[n];
}
function announce(num) {
  window.speechSynthesis.cancel();
  const numStr = String(num).padStart(3, '0');
  const u=new SpeechSynthesisUtterance(`หมายเลข ${numStr} รับสินค้าได้เลยค่ะ`);
  const v=voices.find(v=>v.lang==='th-TH')||voices.find(v=>v.lang.startsWith('th'))||voices[0];
  if (v) u.voice=v; u.lang='th-TH'; u.rate=0.85; u.volume=1.0;
  const b=document.getElementById('vbar');
  u.onstart=()=>{b.textContent=`🔊 ຄິວ ${String(num).padStart(3,'0')}`;b.className='vbar sp';};
  u.onend=u.onerror=()=>{b.textContent='🔇 ລໍຖ້າ';b.className='vbar';};
  window.speechSynthesis.speak(u);
}

