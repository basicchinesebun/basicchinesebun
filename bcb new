.progress-fill{background:var(--cream);height:4px;transition:width 0.3s;}

/* Content */
.content{flex:1;overflow-y:auto;padding:16px 14px;display:flex;flex-direction:column;gap:14px;}
.bbar{padding:14px 12px;border-top:2px solid var(--cream3);background:var(--warm-white);flex-shrink:0;display:flex;flex-direction:column;gap:8px;}

/* Buttons */
