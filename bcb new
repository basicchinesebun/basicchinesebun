function renderChart(){
  const sales=getSales();const chart=document.getElementById('salesChart');const days=[];
  for(let i=6;i>=0;i--){const d=new Date();d.setDate(d.getDate()-i);const key=d.toLocaleDateString('lo-LA');days.push({key,label:(d.getMonth()+1)+'/'+d.getDate(),total:sales[key]?.total||0});}
  const maxV=Math.max(...days.map(d=>d.total),1);
  if(days.every(d=>d.total===0)){chart.innerHTML='<div class="chart-empty">ຍັງບໍ່ມີຂໍ້ມູນ</div>';return;}
  chart.innerHTML=days.map(d=>{
    const pct=Math.max(2,Math.round((d.total/maxV)*130));
    const vl=d.total>0?(d.total>=1000?Math.round(d.total/1000)+'k':d.total):'';
    return `<div class="cbar-wrap"><div class="cbar" style="height:${pct}px">${vl?`<div class="cbar-val">${vl}</div>`:''}</div><div class="cbar-lbl">${d.label}</div></div>`;
  }).join('');
}
