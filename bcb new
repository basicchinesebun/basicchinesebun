<!DOCTYPE html>
<html lang="lo">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Basic Chinese Bun — Staff</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+Lao:wght@400;700;900&family=Playfair+Display:wght@700;900&family=IBM+Plex+Mono:wght@400;700&display=swap');
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
:root{
  --brown:#3d1f0a;        /* น้ำตาลเข้ม — หัว/ปุ่มหลัก */
  --brown2:#6b3a1f;       /* น้ำตาลกลาง */
  --brown3:#a0522d;       /* น้ำตาลอ่อน — accent */
  --cream:#fdf6ee;        /* พื้นหลังหลัก */
  --cream2:#f5ebe0;       /* พื้นหลัง card */
  --cream3:#e8d5c0;       /* border/divider */
  --warm-white:#fffbf6;   /* card bg */
  --gray3:#8a6a55;        /* text รอง */
  --green:#2d6a2d;--red:#b91c1c;--blue:#1a4d8f;--orange:#c45c00;
  --green-bg:#e8f5e8;--red-bg:#fef2f2;--blue-bg:#eff6ff;--orange-bg:#fff4e5;
  --radius:14px;--radius-sm:10px;
  --shadow:0 2px 12px rgba(61,31,10,0.10);
}
body{font-family:'Noto Sans Lao',sans-serif;word-break:break-word;background:var(--cream);color:var(--brown);min-height:100vh;font-size:17px;padding-bottom:64px;}
input,textarea{font-size:16px!important;}
button{font-family:'Noto Sans Lao',sans-serif;word-break:break-word;cursor:pointer;}

/* ── Pages ── */
.page{display:none;}
.page.active{display:block;}

/* ── Toast ── */
#toast{position:fixed;bottom:76px;left:50%;transform:translateX(-50%);z-index:9000;display:flex;flex-direction:column;gap:8px;align-items:center;pointer-events:none;}
.toast-item{padding:10px 20px;border-radius:30px;font-size:15px;font-weight:700;color:var(--cream);background:var(--brown);box-shadow:0 4px 16px rgba(61,31,10,0.25);animation:fadeUp 0.3s ease;white-space:nowrap;}
.toast-item.green{background:var(--green);}
.toast-item.red{background:var(--red);}
.toast-item.blue{background:var(--blue);}
.toast-item.orange{background:var(--orange);}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

/* ── Bottom Nav ── */
.bottom-nav{position:fixed;bottom:0;left:0;right:0;background:var(--brown);display:flex;border-top:2px solid var(--brown2);z-index:200;}
.nav-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:12px 4px;border:none;background:transparent;color:rgba(253,246,238,0.45);font-family:'Noto Sans Lao',sans-serif;word-break:break-word;font-size:13px;font-weight:700;gap:3px;cursor:pointer;transition:color 0.15s;}
.nav-item.active{color:var(--cream);}
.nav-item:active{opacity:0.7;}
.nav-icon{font-size:clamp(18px,2.5vw,22px);line-height:1;}

/* ── Shared Header ── */
.hdr{background:var(--brown);padding:12px 16px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;gap:8px;}
.hdr-title{font-family:'Playfair Display',serif;font-size:clamp(16px,2.5vw,20px);font-weight:900;color:var(--cream);flex-shrink:0;font-weight:900;color:var(--cream);flex-shrink:0;}
.hdr-center{font-family:'Playfair Display',serif;font-size:clamp(16px,2.5vw,20px);font-weight:900;color:var(--cream);flex:1;text-align:center;font-weight:900;color:var(--cream);flex:1;text-align:center;}
.hdr-btns{display:flex;gap:5px;flex-wrap:wrap;justify-content:flex-end;}
.hbtn{padding:clamp(7px,1.2vw,10px) clamp(9px,1.5vw,12px);border-radius:8px;font-size:clamp(12px,1.5vw,14px);font-weight:900;border:1.5px solid rgba(253,246,238,0.35);background:transparent;color:var(--cream);white-space:nowrap;font-weight:900;border:1.5px solid rgba(253,246,238,0.35);background:transparent;color:var(--cream);white-space:nowrap;}
.hbtn:active{opacity:0.7;}
.hbtn.blue{border-color:#93c5fd;color:#93c5fd;}
.hbtn.green{border-color:#86efac;color:#86efac;}
.hbtn.red{border-color:#fca5a5;color:#fca5a5;}
.notif-wrap{position:relative;}
.notif-dot{width:9px;height:9px;background:#ff5252;border-radius:50%;position:absolute;top:3px;right:3px;display:none;animation:pulse 1.2s infinite;}
@keyframes pulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.4);opacity:0.5}}

/* ══════════════════════════════════
   PAGE 1 — ORDERS (display)
══════════════════════════════════ */
/* iPhone — single column */
.layout{display:flex;flex-direction:column;max-width:1200px;margin:0 auto;}
.sidebar{padding:12px 12px 0;display:flex;flex-direction:column;gap:10px;}
.main-col{padding:12px;display:flex;flex-direction:column;gap:10px;min-height:200px;}

/* iPad/Tablet — two column side by side */
@media(min-width:768px){
  .layout{display:grid!important;grid-template-columns:320px 1fr!important;align-items:start;}
  .sidebar{position:sticky;top:57px;max-height:calc(100vh - 57px);overflow-y:auto;padding:12px 12px 0;}
  .main-col{min-height:calc(100vh - 80px);}
}

.card{background:var(--warm-white);border:1.5px solid var(--cream3);border-radius:var(--radius);padding:14px;box-shadow:var(--shadow);}
.card-title{font-size:13px;font-weight:900;color:var(--brown3);letter-spacing:0.3px;text-transform:uppercase;margin-bottom:12px;}

/* Collapsible */
.card-collapsible .card-title{display:flex;align-items:center;justify-content:space-between;cursor:pointer;margin-bottom:0;user-select:none;}
.card-collapsible .card-title::after{content:'▾';font-size:14px;color:var(--brown3);transition:transform 0.25s;flex-shrink:0;}
.card-collapsible.collapsed .card-title::after{transform:rotate(-90deg);}
.card-collapsible .card-body{overflow:hidden;max-height:600px;transition:max-height 0.3s ease,opacity 0.25s ease,margin-top 0.25s ease;opacity:1;margin-top:12px;}
.card-collapsible.collapsed .card-body{max-height:0;opacity:0;margin-top:0;}

.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;}
.stat{background:var(--warm-white);border:1.5px solid var(--cream3);border-radius:var(--radius-sm);padding:10px 6px;text-align:center;}
.stat-num{font-size:clamp(22px,3vw,28px);font-weight:900;color:var(--brown);}
.stat-lbl{font-size:13px;font-weight:700;color:var(--gray3);margin-top:2px;}

.tsw{width:48px;height:26px;background:var(--cream3);border-radius:13px;cursor:pointer;position:relative;border:none;transition:background 0.2s;flex-shrink:0;}
.tsw.on{background:var(--brown);}
.tsw::after{content:'';position:absolute;width:20px;height:20px;background:var(--cream);border-radius:50%;top:3px;left:3px;transition:left 0.2s;}
.tsw.on::after{left:25px;}
.toggle-row{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--cream3);}
.toggle-row:last-child{border-bottom:none;}
.toggle-lbl{font-size:16px;font-weight:700;color:var(--brown);}
.toggle-sub{font-size:12px;color:var(--gray3);margin-top:2px;}

.stock-row{display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid var(--cream2);}
.stock-row:last-child{border-bottom:none;}
.stock-name{font-size:13px;font-weight:700;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--brown);}
.sbadge{font-size:10px;font-weight:900;border-radius:5px;padding:2px 7px;flex-shrink:0;}
.sbadge.low{background:var(--orange-bg);color:var(--orange);}
.sbadge.out{background:var(--red-bg);color:var(--red);}
.sctrl{display:flex;align-items:center;gap:5px;flex-shrink:0;}
.sbtn{width:30px;height:30px;border:1.5px solid var(--brown3);border-radius:50%;background:var(--warm-white);font-size:16px;font-weight:900;display:flex;align-items:center;justify-content:center;color:var(--brown);}
.sbtn:active{background:var(--cream2);}
.sinput{width:52px;height:32px;border:1.5px solid var(--brown3);border-radius:8px;text-align:center;font-size:15px;font-weight:900;background:var(--warm-white);color:var(--brown);}
.sinput.low{border-color:var(--orange);color:var(--orange);}
.sinput.out{border-color:var(--cream3);color:var(--cream3);}

/* Menu settings rows */
.menu-set-row{display:flex;align-items:center;gap:6px;padding:7px 0;border-bottom:1px solid var(--cream2);}
.menu-set-row:last-child{border-bottom:none;}
.menu-set-num{font-size:11px;font-weight:900;color:var(--cream3);min-width:18px;}
.menu-set-name{flex:2;min-width:0;border:1.5px solid var(--cream3);border-radius:7px;padding:6px 8px;font-size:13px;font-weight:700;font-family:'Noto Sans Lao',sans-serif;word-break:break-word;color:var(--brown);background:var(--cream);}
.menu-set-price{width:72px;border:1.5px solid var(--cream3);border-radius:7px;padding:6px 8px;font-size:13px;font-weight:700;font-family:'Noto Sans Lao',sans-serif;word-break:break-word;text-align:right;color:var(--brown);background:var(--cream);}
.menu-set-unit{font-size:11px;color:var(--gray3);font-weight:700;flex-shrink:0;}
.menu-set-img{flex-shrink:0;}
.menu-set-img label{display:flex;align-items:center;justify-content:center;width:30px;height:30px;border:1.5px solid var(--brown3);border-radius:7px;font-size:14px;cursor:pointer;background:var(--cream);}

.pstatus{border-radius:var(--radius-sm);padding:9px 14px;font-size:13px;font-weight:700;display:none;text-align:center;}
.pstatus.show{display:block;}
.pstatus.connecting{background:var(--blue-bg);border:1.5px solid #90caf9;color:var(--blue);}
.pstatus.connected{background:var(--green-bg);border:1.5px solid #a5d6a7;color:var(--green);}
.pstatus.error{background:var(--red-bg);border:1.5px solid #ef9a9a;color:var(--red);}

.vbar{background:#fff;border:1.5px solid var(--gray2);border-radius:var(--radius-sm);padding:9px 14px;text-align:center;font-size:13px;font-weight:700;color:#bbb;}
.vbar.sp{color:#000;border-color:#000;}

.orders-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.orders-title{font-size:14px;font-weight:900;letter-spacing:0.3px;text-transform:uppercase;color:var(--gray3);}
.show-done-btn{font-size:13px;font-weight:900;color:var(--brown3);background:var(--warm-white);border:1.5px solid var(--cream3);border-radius:7px;padding:6px 12px;}
.olist{display:flex;flex-direction:column;gap:10px;}
.empty-msg{text-align:center;color:var(--cream3);font-size:16px;font-weight:700;padding:40px 0;}

.ocard{background:var(--warm-white);border:2px solid var(--brown);border-radius:var(--radius);overflow:hidden;}
.ocard.done{border-color:var(--cream3);}
.ocard.cancelled{border-color:#fca5a5;background:#fff9f9;}
.ocard.hidden{display:none;}
@keyframes highlight{0%,100%{box-shadow:none}50%{box-shadow:0 0 0 3px var(--brown)}}
.istrip{display:flex;flex-wrap:wrap;background:var(--cream2);min-height:80px;}
.iitem{flex-shrink:0;width:80px;height:80px;position:relative;}
.iitem img,.iemoji{width:100%;height:100%;object-fit:cover;}
.iemoji{display:flex;align-items:center;justify-content:center;font-size:36px;background:var(--cream2);}
.iqty{position:absolute;bottom:4px;right:4px;background:rgba(61,31,10,0.8);color:var(--cream);font-size:12px;font-weight:900;border-radius:5px;padding:2px 5px;}
.obody{padding:14px;}
.ohead{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;}
.oqnum{font-family:'Playfair Display',serif;font-size:clamp(22px,3vw,30px);font-weight:900;line-height:1;color:var(--brown);}
.oright{text-align:right;}
.otime{font-size:14px;font-weight:700;color:var(--gray3);}
.tag{display:inline-block;font-size:12px;font-weight:900;border-radius:5px;padding:2px 8px;letter-spacing:1px;margin-top:3px;}
.tag-called{background:var(--brown);color:var(--cream);}
.tag-done{background:var(--green-bg);color:var(--green);}
.tag-cancelled{background:var(--red-bg);color:var(--red);}
.oitems{font-size:clamp(13px,1.8vw,16px);font-weight:700;color:var(--brown2);line-height:1.9;white-space:pre-line;margin-bottom:8px;}
.ototal{font-size:20px;font-weight:900;margin-bottom:12px;color:var(--brown);}
.oactions{display:flex;gap:7px;flex-wrap:wrap;}
.abtn{padding:14px 10px;border-radius:10px;font-size:15px;font-weight:900;border:none;text-align:center;flex:1;min-width:0;font-weight:900;border:none;text-align:center;flex:1;min-width:0;}
.abtn:active{opacity:0.7;}
.abtn-one{background:var(--brown);color:var(--cream);flex:4;font-size:17px;}
.abtn-call{background:var(--brown2);color:var(--cream);flex:2;}
.abtn-rep{background:var(--warm-white);color:var(--brown);border:1.5px solid var(--brown3)!important;}
.abtn-print{background:var(--blue-bg);color:var(--blue);border:1.5px solid #93c5fd!important;}
.abtn-cancel{background:var(--warm-white);color:var(--red);border:1.5px solid var(--red)!important;}
.abtn-undo{background:var(--warm-white);color:var(--gray3);border:1.5px solid var(--cream3)!important;width:100%;}

.data-btns{display:flex;gap:8px;}
.dbtn{flex:1;padding:11px;border-radius:var(--radius-sm);font-size:13px;font-weight:900;text-align:center;border:none;cursor:pointer;}
.dbtn-export{background:var(--brown);color:var(--cream);}
.dbtn-import{background:var(--warm-white);color:var(--brown);border:1.5px solid var(--brown3)!important;}
.dbtn-firebase{background:var(--warm-white);color:var(--orange);border:1.5px solid var(--orange)!important;width:100%;margin-top:8px;padding:11px;border-radius:var(--radius-sm);}

.modal-bg{display:none;position:fixed;inset:0;background:rgba(61,31,10,0.55);z-index:500;align-items:center;justify-content:center;padding:20px;}
.modal-bg.show{display:flex;}
.modal{background:var(--warm-white);border:2px solid var(--brown);border-radius:18px;max-width:360px;width:100%;padding:22px;}
.modal-title{font-size:18px;font-weight:900;text-align:center;margin-bottom:7px;color:var(--brown);}
.modal-sub{font-size:12px;color:var(--gray3);font-weight:700;text-align:center;margin-bottom:18px;}
.mbtn{width:100%;padding:14px;border-radius:var(--radius-sm);font-size:16px;font-weight:900;margin-bottom:9px;font-family:'Noto Sans Lao',sans-serif;word-break:break-word;cursor:pointer;}
.mbtn.black{background:var(--brown);color:var(--cream);border:none;}
.mbtn.outline{background:var(--warm-white);color:var(--brown);border:1.5px solid var(--brown);}
.mbtn.red{background:var(--warm-white);color:var(--red);border:1.5px solid var(--red);}

/* ══════════════════════════════════
   PAGE 2 — SALES
══════════════════════════════════ */
.sales-content{max-width:480px;margin:0 auto;padding:16px 14px;}
.date-row{display:flex;gap:8px;align-items:center;margin-bottom:16px;}
.dlbl{font-size:12px;font-weight:900;color:var(--gray3);letter-spacing:0.3px;text-transform:uppercase;}
.dsel{border:1.5px solid var(--brown3);border-radius:10px;padding:8px 12px;font-size:14px;font-weight:700;font-family:'Noto Sans Lao',sans-serif;word-break:break-word;background:var(--warm-white);color:var(--brown);cursor:pointer;flex:1;}
.chart-box{background:var(--warm-white);border:1.5px solid var(--cream3);border-radius:14px;padding:16px;margin-bottom:16px;}
.chart-title{font-size:11px;font-weight:900;color:var(--gray3);letter-spacing:0.3px;text-transform:uppercase;margin-bottom:12px;}
.chart-wrap{position:relative;height:160px;display:flex;align-items:flex-end;gap:6px;padding-bottom:24px;}
.cbar-wrap{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;height:100%;}
.cbar{width:100%;background:var(--brown);border-radius:6px 6px 0 0;min-height:2px;position:relative;transition:height 0.4s;}
.cbar-val{position:absolute;top:-18px;left:50%;transform:translateX(-50%);font-size:9px;font-weight:900;color:var(--brown);white-space:nowrap;}
.cbar-lbl{font-size:9px;font-weight:700;color:var(--gray3);margin-top:4px;text-align:center;}
.chart-empty{text-align:center;color:var(--cream3);font-size:13px;font-weight:700;padding:40px 0;}
.total-box{background:var(--brown);border-radius:14px;padding:18px 20px;display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;}
.total-lbl{font-size:13px;font-weight:700;color:rgba(253,246,238,0.6);letter-spacing:0.3px;text-transform:uppercase;}
.total-amt{font-family:'Playfair Display',serif;font-size:clamp(22px,3vw,28px);font-weight:900;color:var(--cream);font-weight:900;color:var(--cream);}
.scards{display:flex;gap:10px;margin-bottom:16px;}
.sc{flex:1;background:var(--warm-white);border:1.5px solid var(--cream3);border-radius:14px;padding:14px 10px;text-align:center;}
.sc-num{font-size:clamp(20px,3vw,26px);font-weight:900;color:var(--brown);}
.sc-lbl{font-size:12px;font-weight:700;color:var(--gray3);margin-top:4px;letter-spacing:1px;text-transform:uppercase;}
.divider{height:2px;background:var(--cream3);border-radius:2px;margin:16px 0;}
.sec-t{font-size:11px;font-weight:900;letter-spacing:0.5px;text-transform:uppercase;color:var(--gray3);margin-bottom:12px;}
.mb-box{background:var(--warm-white);border:1.5px solid var(--cream3);border-radius:12px;padding:14px;margin-bottom:16px;}
.mb-row{display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid var(--cream2);}
.mb-row:last-child{border-bottom:none;}
.mb-name{font-size:15px;font-weight:700;color:var(--brown);}
.mb-qty{font-size:15px;font-weight:900;color:var(--brown2);}
.sale-list{display:flex;flex-direction:column;gap:8px;}
.scard{background:var(--warm-white);border:1.5px solid var(--cream3);border-radius:12px;padding:12px 14px;}
.scard-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;}
.scard-qnum{font-size:17px;font-weight:900;color:var(--brown);}
.scard-time{font-size:11px;font-weight:700;color:var(--gray3);}
.scard-items{font-size:14px;font-weight:700;color:var(--brown2);line-height:1.7;white-space:pre-line;margin-bottom:4px;}
.scard-total{font-size:16px;font-weight:900;text-align:right;color:var(--brown);}
.s-empty{text-align:center;color:var(--cream3);font-size:14px;font-weight:700;padding:40px 0;}
.clear-btn{width:100%;padding:13px;background:var(--warm-white);color:var(--red);border:1.5px solid var(--red);border-radius:12px;font-size:14px;font-weight:900;cursor:pointer;font-family:'Noto Sans Lao',sans-serif;word-break:break-word;margin-top:8px;}

/* ══════════════════════════════════
   PAGE 3 — RECEIPT
══════════════════════════════════ */
.receipt-content{max-width:480px;margin:0 auto;padding:16px 14px;display:flex;flex-direction:column;gap:14px;}
.rcard{background:var(--warm-white);border:1.5px solid var(--cream3);border-radius:16px;padding:18px;}
.rcard-title{font-size:13px;font-weight:900;color:var(--brown3);letter-spacing:0.5px;text-transform:uppercase;margin-bottom:14px;}
.field{margin-bottom:12px;}
.field:last-child{margin-bottom:0;}
.field label{display:block;font-size:13px;font-weight:900;color:var(--brown2);margin-bottom:6px;}
.field input,.field textarea{width:100%;border:1.5px solid var(--cream3);border-radius:10px;padding:11px 13px;font-size:16px;font-weight:700;font-family:'Noto Sans Lao',sans-serif;word-break:break-word;resize:none;background:var(--cream);color:var(--brown);}
.field textarea{height:75px;}
.logo-wrap{display:flex;gap:12px;align-items:center;}
.logo-preview{width:72px;height:72px;border:1.5px solid var(--cream3);border-radius:12px;overflow:hidden;display:flex;align-items:center;justify-content:center;background:var(--cream2);flex-shrink:0;}
.logo-preview img{width:100%;height:100%;object-fit:contain;display:none;}
.logo-upload{flex:1;border:1.5px solid var(--brown3);border-radius:10px;padding:11px;text-align:center;font-size:14px;font-weight:900;cursor:pointer;background:var(--cream);color:var(--brown);}
.logo-rm{font-size:13px;font-weight:700;color:var(--red);cursor:pointer;background:none;border:none;display:none;padding:4px 0;}
.tog-row{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--cream3);}
.tog-row:last-child{border-bottom:none;}
.tog-lbl{font-size:15px;font-weight:700;color:var(--brown);}
.rtsw{width:48px;height:28px;background:var(--cream3);border-radius:14px;cursor:pointer;position:relative;border:none;flex-shrink:0;transition:background 0.2s;}
.rtsw.on{background:var(--brown);}
.rtsw::after{content:'';position:absolute;width:22px;height:22px;background:var(--cream);border-radius:50%;top:3px;left:3px;transition:left 0.2s;}
.rtsw.on::after{left:23px;}
.save-btn{width:100%;padding:17px;background:var(--brown);color:var(--cream);border:none;border-radius:14px;font-family:'Noto Sans Lao',sans-serif;word-break:break-word;font-size:17px;font-weight:900;cursor:pointer;}
.saved-msg{text-align:center;font-size:14px;font-weight:700;color:var(--green);display:none;margin-top:8px;}
.prev-outer{background:var(--warm-white);border:1.5px solid var(--cream3);border-radius:16px;padding:18px;}
.prev-lbl{font-size:11px;font-weight:900;color:var(--gray3);letter-spacing:0.5px;text-transform:uppercase;margin-bottom:14px;}
.receipt-paper{font-family:'IBM Plex Mono',monospace;background:#fff;border:1.5px dashed var(--cream3);border-radius:10px;padding:18px 14px;max-width:300px;margin:0 auto;font-size:13px;line-height:1.6;}
.r-logo{width:80px;height:80px;object-fit:contain;display:block;margin:0 auto 10px;}
.r-shop{font-size:18px;font-weight:700;text-align:center;line-height:1.3;}
.r-addr,.r-phone{font-size:11px;text-align:center;color:#555;margin-top:2px;}
.r-div{border:none;border-top:1.5px dashed var(--cream3);margin:10px 0;}
.r-qlbl{font-size:11px;text-align:center;color:#888;letter-spacing:0.3px;text-transform:uppercase;}
.r-qnum{font-family:'Playfair Display',serif;font-size:52px;font-weight:900;text-align:center;line-height:1.1;}
.r-time{font-size:11px;color:#888;margin-top:4px;}
.r-item{display:flex;justify-content:space-between;font-size:13px;font-weight:700;padding:2px 0;line-height:1.6;}
.r-total{display:flex;justify-content:space-between;font-size:16px;font-weight:700;margin-top:4px;}
.r-foot{font-size:12px;text-align:center;color:#555;margin-top:10px;line-height:1.6;font-style:italic;}
.ptest-btn{width:100%;padding:14px;background:var(--warm-white);color:var(--blue);border:1.5px solid var(--blue);border-radius:14px;font-family:'Noto Sans Lao',sans-serif;word-break:break-word;font-size:15px;font-weight:900;cursor:pointer;margin-top:14px;}
input[type=file]{display:none;}
</style>
</head>
<body>

<div id="toast"></div>

<!-- ══════════════════════════════════
