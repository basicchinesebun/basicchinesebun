function todayKey() { return new Date().toLocaleDateString('lo-LA'); }
function addSale(o) {
  const s=getSales(),k=todayKey();
  if (!s[k]) s[k]={total:0,count:0,items:[]};
  s[k].total+=(o.total||0); s[k].count+=1;
  s[k].items.push({num:o.num,total:o.total||0,time:o.time,items:o.items});
  saveSales(s);
}
function remSale(o) {
  const s=getSales(),k=todayKey(); if (!s[k]) return;
  s[k].total=Math.max(0,(s[k].total||0)-(o.total||0));
  s[k].count=Math.max(0,(s[k].count||0)-1);
  s[k].items=(s[k].items||[]).filter(x=>x.num!==o.num);
  saveSales(s);
}

