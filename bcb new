function render() {
  const orders=getOrders();
  const list=document.getElementById('orderList');
  // ถ้าไม่มี active orders ให้ show done อัตโนมัติ
  const hasActive = orders.some(o=>!o.done&&!o.cancelled);
  if (!hasActive && orders.length > 0 && !showDone) {
    showDone = true;
    const btn = document.getElementById('showDoneBtn');
    if (btn) btn.textContent = 'ເຊື່ອງທີ່ສຳເລັດ';
  }
  if (!orders.length) { list.innerHTML='<div class="empty-msg">ຍັງບໍ່ມີລາຍການ</div>'; updateStats(); return; }
  list.innerHTML=orders.map((o,i)=>{
    // ซ่อน cancelled ออกเลย ไม่ปนกับรายการปกติ
    const hide=(o.done&&!showDone)||(o.cancelled&&!showCancelled);
    const tag=o.cancelled?`<span class="tag tag-cancelled">✕ ຍົກເລີກ</span>`
      :o.done?`<span class="tag tag-done">✓ ສຳເລັດ</span>`
      :o.called?`<span class="tag tag-called">📢 ຮຽກ</span>`:'';
    let act;
    if (o.cancelled) act=`<button class="abtn abtn-undo" onclick="undoCancel(${i})">↩ ຄືນ</button>`;
    else if (o.done) act=`<button class="abtn abtn-undo" onclick="undoDone(${i})">↩ ຍົກເລີກ Done</button>`;
    else if (o.type==='online' && o.status==='pending') act=`
      <button class="abtn" style="background:var(--green);color:var(--cream);flex:3;" onclick="confirmSlip(${o.num})">✅ ຢືນຢັນສລິບ</button>
      <button class="abtn" style="background:var(--warm-white);color:var(--red);border:2px solid var(--red)!important;flex:2;" onclick="rejectSlip(${o.num})">❌ ປະຕິເສດ</button>`;
    else act=`
      <button class="abtn abtn-one" onclick="oneActionDone(${i})">⚡ Done</button>
      <button class="abtn abtn-call" onclick="callOnly(${i})">📢</button>
      <button class="abtn abtn-rep" onclick="announce(${o.num})">🔁</button>
      <button class="abtn abtn-print" onclick="printOrder(${i})">🖨</button>
      <button class="abtn abtn-cancel" onclick="cancelOrder(${i})">✕</button>`;
    return `<div class="ocard ${o.done?'done':''} ${o.cancelled?'cancelled':''} ${hide?'hidden':''}">
      <div class="istrip">${buildImgStrip(o.items)}</div>
      <div class="obody">
        <div class="ohead"><div class="oqnum">ຄິວ ${String(o.num).padStart(3,'0')}</div>
        <div class="oright"><div class="otime">${o.time}</div>
        ${o.type==='online'?'<span class="tag" style="background:var(--blue-bg);color:var(--blue);">🌐 ອອນໄລນ໌</span>':''}
