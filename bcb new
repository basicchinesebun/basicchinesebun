.sold-lbl{color:var(--cream);font-size:clamp(13px,2vw,16px);font-weight:900;background:rgba(185,28,28,0.9);padding:6px 10px;border-radius:8px;}
.cbadge{position:absolute;top:6px;right:6px;width:26px;height:26px;background:var(--brown);border-radius:50%;display:none;align-items:center;justify-content:center;color:var(--cream);font-size:13px;z-index:2;}
.mcard.sel .cbadge{display:flex;}
