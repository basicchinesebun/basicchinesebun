  document.getElementById('cntOrders').textContent=data.count||0;
  const avg=data.count?Math.round(data.total/data.count):0;
  document.getElementById('avgOrd').textContent=avg?avg.toLocaleString():'0';
  const counts={};
  (data.items||[]).forEach(o=>{o.items.split('\n').forEach(line=>{if(!line.trim())return;const q=parseInt((line.match(/[x×](\d+)/)||[,'1'])[1]);const name=line.split(/[x×]/)[0].trim();if(!name)return;counts[name]=(counts[name]||0)+q;});});
  const sorted=Object.entries(counts).sort((a,b)=>b[1]-a[1]);
  document.getElementById('topMenu').textContent=sorted.length?sorted[0][0].substring(0,8):'—';
