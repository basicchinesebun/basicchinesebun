<script>
'use strict';
const ESC = 0x1B, GS = 0x1D;
const EMOJIS = ['🥟','🍫','🍵','🧁','🍞','🥐','🍮'];
let btDevice = null, btChar = null;
let voices = [], showDone = false, showCancelled = false, autoPrint = false, soundOn = true;
let lastPendingCount = 0, undoStack = [];

// ── Page switching (replaces cross-file links) ──
function switchPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  document.getElementById('nav-' + name).classList.add('active');
  window.scrollTo(0, 0);
  if (name === 'sales') { loadDates(); renderSales(); renderChart(); }
  if (name === 'receipt') { loadReceipt(); }
}

// ── Toast ──
function toast(msg, type='', duration=2500) {
  const el = document.createElement('div');
  el.className = `toast-item ${type}`; el.textContent = msg;
  document.getElementById('toast').appendChild(el);
  setTimeout(() => el.style.opacity='0', duration-300);
  setTimeout(() => el.remove(), duration);
}

// ── Shop Open/Close ──
function getShopStatus() { return JSON.parse(localStorage.getItem('bcb_shop')||'{"open":false,"dates":[]}'); }
function saveShopStatus(s) {
  localStorage.setItem('bcb_shop', JSON.stringify(s));
  if(fbDb){
    import('https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js').then(({ref,set})=>{
      set(ref(fbDb,'shop'),s).catch(()=>{});
    });
  }
}
function toggleShop() {
  const s = getShopStatus();
  s.open = !s.open;
  if(s.open) {
    const today = new Date().toISOString().split('T')[0];
    if(!s.dates.includes(today)) s.dates.push(today);
  }
  saveShopStatus(s);
  renderShopStatus();
