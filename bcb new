// ── QR Admin ──
function uploadQRAdmin(e){
  const f=e.target.files[0];if(!f)return;
  const reader=new FileReader();
  reader.onload=ev=>{
    // บีบอัดรูป QR ก่อนบันทึก
    const img=new Image();
    img.onload=()=>{
      const canvas=document.createElement('canvas');
      const MAX=800;
      let w=img.width,h=img.height;
      if(w>MAX){h=Math.round(h*MAX/w);w=MAX;}
      canvas.width=w;canvas.height=h;
      canvas.getContext('2d').drawImage(img,0,0,w,h);
      const data=canvas.toDataURL('image/jpeg',0.7);
      localStorage.setItem('bcb_qr',data);
      renderQRAdmin();
      // sync ขึ้น Firebase ด้วย
      if(fbDb){
        import('https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js').then(({ref,set})=>{
          set(ref(fbDb,'settings/qr'),data).then(()=>toast('ອັບໂຫລດ QR ✅ — sync ແລ້ວ','green')).catch(()=>toast('ອັບໂຫລດ QR ✅','green'));
        });
      } else { toast('ອັບໂຫລດ QR ✅','green'); }
    };
    img.src=ev.target.result;
  };
  reader.readAsDataURL(f);
}
function removeQR(){
  if(!confirm('ລຶບ QR Code?'))return;
  localStorage.removeItem('bcb_qr');
