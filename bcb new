function _alertLowStock(name,isOut) {
  if (!soundOn) return;
  toast(isOut?`⚠️ "${name}" ໝົດ!`:`⚠️ "${name}" ໃກ້ໝົດ`,'orange');
  try {
    const ctx=new(window.AudioContext||window.webkitAudioContext)();
    const g=ctx.createGain();g.gain.value=0.2;g.connect(ctx.destination);
    const o=ctx.createOscillator();o.connect(g);o.frequency.value=isOut?440:660;o.start();o.stop(ctx.currentTime+0.3);
  } catch(e){}
}
function deductStock(itemsText, type='walkin') {
  const mn=getMenuNames(), st=getStock(type), stTotal=getStock('total');
  itemsText.split('\n').forEach(line=>{
    if (!line.trim()) return;
    const qtyMatch=line.match(/x(\d+)/);
    const qty=qtyMatch?parseInt(qtyMatch[1]):1;
    const idx=mn.findIndex(m=>line.includes(m.lo));
    if (idx>=0) {
      st[idx]=Math.max(0,(st[idx]||0)-qty);
      stTotal[idx]=Math.max(0,(stTotal[idx]||0)-qty);
    }
  });
  saveStock(st, type);
  saveStock(stTotal, 'total');
  renderStock();
}

